ROOSTY_OBJECT_STORAGE_BACKEND=local
ROOSTY_REGISTRATION_MODE={{ roosty_registration_mode }}
ROOSTY_FEDERATION_ENABLED={{ roosty_federation_enabled | lower }}
ROOSTY_FEDERATION_ALLOWED_DOMAINS={{ roosty_federation_allowed_domains | join(',') }}
ROOSTY_FEDERATION_BLOCKED_DOMAINS={{ roosty_federation_blocked_domains | join(',') }}
ROOSTY_FEDERATION_DELIVERY_MAX_AGE={{ roosty_federation_delivery_max_age }}
