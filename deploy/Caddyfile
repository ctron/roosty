https://localhost:4000, https://roosty.localhost:4000 {
	tls internal
	reverse_proxy roosty:4000
}

https://localhost:4001 {
	tls internal

	handle /reset {
		header Clear-Site-Data "\"cache\", \"cookies\", \"storage\""
		respond "Elk local browser state cleared. Open https://localhost:4001/ again." 200
	}

	reverse_proxy elk:5314
}

# Reuse Caddy to expose Phanpy without adding another local container. The
# upstream is a static web application; API and OAuth requests still go directly
# to the selected Roosty instance.
https://localhost:4002 {
	tls internal
	reverse_proxy https://phanpy.social {
		header_up Host phanpy.social
	}
}
