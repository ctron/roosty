https://localhost:4000, https://roosty.localhost:4000 {
	tls internal
	reverse_proxy roosty:4000
}

https://localhost:4001 {
	tls internal

	handle /reset {
		header Clear-Site-Data "\"cache\", \"cookies\", \"storage\""
		respond "Elk local browser state cleared. Open https://localhost:4001/ again." 200
	}

	reverse_proxy elk:5314
}

# Phanpy is baked into the local Caddy image from a pinned upstream release.
https://localhost:4002 {
	tls internal
	route {
		@phanpy_root {
			path /
			not query default=1
		}
		redir @phanpy_root /?default=1#/login?instance=roosty.localhost:4000 302
		root * /srv/phanpy
		try_files {path} /index.html
		file_server
	}
}
