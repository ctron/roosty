# syntax=docker/dockerfile:1.7

FROM docker.io/library/rust:bookworm AS builder

ARG TARGETPLATFORM

WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,id=cargo-target-${TARGETPLATFORM},target=/cargo-target,sharing=locked \
    CARGO_TARGET_DIR=/cargo-target cargo build --release --locked -p roosty \
    && cp /cargo-target/release/roosty /usr/local/bin/roosty

FROM docker.io/library/debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && install -d -o 65532 -g 65532 /var/lib/roosty/media \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/bin/roosty /usr/local/bin/roosty

USER 65532:65532
ENTRYPOINT ["/usr/local/bin/roosty"]
