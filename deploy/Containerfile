FROM docker.io/library/rust:1.85-bookworm AS builder

WORKDIR /src
COPY . .
RUN cargo build --release --locked -p roost

FROM docker.io/library/debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/roost /usr/local/bin/roost

USER 65532:65532
ENTRYPOINT ["/usr/local/bin/roost"]
